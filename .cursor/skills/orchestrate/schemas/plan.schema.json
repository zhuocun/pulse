                      "minLength": 1,
                      "description": "Shell command executed under `bash -c` in a fresh checkout of the worker's branch."
                    },
                    "parser": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "const": "wc-l"
                            }
                          },
                          "required": [
