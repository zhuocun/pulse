{
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude)backend/'",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://pulse-python-server.vercel.app/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
