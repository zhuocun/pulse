{
    "name": "pulse",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "start": "vite --host 0.0.0.0 --port 3000",
        "build": "vite build",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "prepare": "husky",
        "prettier": "prettier --check .",
        "prettier:fix": "prettier --write .",
        "eslint": "eslint src __json_server_mock__ eslint.config.mjs vite.config.ts jest.config.cjs babel.config.cjs commitlint.config.js --fix",
        "pre-commit": "npm run prettier && npm run eslint && npm run typecheck && npm run smoke:ai:prod:check && npm run test:smoke:ai:prod",
        "smoke:ai:prod": "node scripts/production-ai-smoke.js",
        "smoke:ai:prod:check": "node --check scripts/production-ai-smoke.js && node --check scripts/production-ai-smoke.test.js",
        "test:smoke:ai:prod": "node --test scripts/production-ai-smoke.test.js",
        "server": "node __json_server_mock__/server.cjs",
        "backend:dev": "cd backend && uvicorn app.main:app --reload --port 8000",
        "backend:test": "cd backend && pytest"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.1",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@hello-pangea/dnd": "^18.0.1",
        "@reduxjs/toolkit": "^2.11.2",
        "@tanstack/react-query": "^5.100.5",
        "antd": "^6.3.6",
        "dayjs": "^1.11.20",
        "framer-motion": "^12.40.0",
        "qs": "^6.15.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-redux": "^9.2.0",
        "react-router": "^7.14.2",
        "react-router-dom": "^7.14.2"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/jest-axe": "^3.5.9",
        "@types/node": "^25.6.0",
        "@types/qs": "^6.15.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-jest": "^30.3.0",
        "eslint": "^10.2.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "jest-axe": "^10.0.0",
        "jest-environment-jsdom": "^30.3.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-svgr": "^5.2.0",
        "web-vitals": "^5.2.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
