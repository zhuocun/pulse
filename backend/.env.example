DATABASE=mongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/jira?retryWrites=true&w=majority
MONGO_DB=jira
UUID=replace_with_the_express_jwt_secret
# Add the FE production origin (e.g. https://jira-react-app.vercel.app) before
# deploying -- otherwise every browser request 4xxs at the CORS preflight.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional anchored regex for matching multiple FE origins (e.g. PR previews).
# Must start with ^ and end with $; pairing an unanchored regex with
# allow_credentials=True is rejected at boot.
CORS_ORIGIN_REGEX=
PORT=8000

# ---------------------------------------------------------------------------
# PRD v2.1 -- Board Copilot agent server
# ---------------------------------------------------------------------------

# LangGraph short-term checkpointer / long-term store backends.
#
# *** PRODUCTION REQUIRES POSTGRES. ***
# board-brief-agent, task-drafting-agent, task-estimation-agent and
# triage-agent all pause on `interrupt()` to fetch FE-side data, then
# resume on a follow-up request. With the `memory` backends those resume
# requests fail on any deployment that isn't a single long-lived process
# (Vercel cold starts, autoscaling, multi-worker uvicorn -- all of them).
# Set both to "postgres", `pip install ".[postgres-agents]"` (or ".[ai]"),
# and provide a reachable Postgres cluster via POSTGRES_URI or
# AGENT_POSTGRES_URI. The server now logs a WARNING at startup whenever
# either of these is `memory`, so the gotcha is visible in the deploy log.
AGENT_CHECKPOINT_BACKEND=memory
AGENT_STORE_BACKEND=memory
# Optional override; when unset, the agents reuse POSTGRES_URI.
AGENT_POSTGRES_URI=
AGENT_DEFAULT_THREAD_ID=default
AGENT_RECURSION_LIMIT=25

# Hard-cap per agent run; the SSE/invoke endpoints return 504 if exceeded.
# NOTE: Vercel's serverless Python runtime caps response duration at
# 10s (hobby) / 60s (pro) / 300s+ (enterprise). Agent runs that involve
# multiple LLM round-trips, FE-tool interrupts, or large boards will
# routinely exceed the lower tiers; deploy SSE-heavy traffic to a
# long-lived runtime (Fly, Render, ECS, dedicated uvicorn) instead.
AGENT_REQUEST_TIMEOUT_SECONDS=120

# Default autonomy when the FE does not send one. suggest | plan | auto.
AGENT_DEFAULT_AUTONOMY=plan

# Comma-separated project ids that have opted out of AI features (PRD §6.3).
AGENT_DISABLED_PROJECT_IDS=

# Per-project monthly token cap (PRD §5A.7).
#
# The default ``memory`` backend (see BUDGET_BACKEND below) tracks the
# cap in a per-process Python dict, which means a multi-worker deploy
# enforces ``workers x AGENT_BUDGET_MONTHLY_TOKEN_CAP`` and a cold
# start wipes the running tally. Switch BUDGET_BACKEND=redis (and set
# REDIS_URI) so a single shared Redis cluster enforces the real cap
# across every worker / serverless instance.
AGENT_BUDGET_MONTHLY_TOKEN_CAP=1000000

# Selects the rate-limit + budget backends. ``memory`` keeps the
# process-local dicts the test suite and single-process dev rely on;
# ``redis`` swaps both to the Redis-backed implementations in
# ``app/middleware/redis_backends.py`` so every gate check goes
# through a single shared store and the configured caps actually mean
# what they say on multi-worker / serverless hosts. Both backends use
# server-side Lua scripts so the check-and-mutate sequence stays
# atomic across workers without a separate distributed lock. Install
# the ``[redis]`` extra (or ``[ai]``) before flipping these to
# ``redis``; otherwise the lifespan raises a clear RuntimeError.
RATE_LIMIT_BACKEND=memory
BUDGET_BACKEND=memory
# Required when either backend is ``redis`` (or when IDEMPOTENCY_BACKEND
# is ``redis``, see below). Standard URI form:
# redis://[username:password@]host[:port][/db]. Rediss:// (TLS) is
# also accepted by redis-py.
REDIS_URI=

# Idempotency-Key cache (Stripe-style). When the FE sends an
# ``Idempotency-Key: <opaque>`` header on a mutating request
# (``POST /api/v1/agents/{name}/invoke`` or any ``POST /api/ai/{...}``
# route), the server caches the first 2xx response and returns the
# cached body on every subsequent retry with the same key + same body --
# without re-running the agent or re-debiting the per-project budget.
# A retry with the same key but a different body is rejected with 422
# (key reused for a different request); a request that arrives while a
# sibling with the same key is still in flight gets 409 ("in progress").
# Replays carry an ``Idempotent-Replay: true`` header so observers can
# distinguish a cache hit from a fresh run.
#
# ``memory`` keeps the cache process-local (fine for single-worker dev
# and tests); ``redis`` shares it across workers and serverless
# instances using the same ``REDIS_URI`` as the Redis-backed rate-limit /
# budget backends. Multi-worker / serverless deploys MUST switch to
# ``redis`` so a retry that lands on a different worker still hits the
# cache; otherwise the protection collapses.
IDEMPOTENCY_BACKEND=memory
# TTL after which a cached response is eligible for eviction. 86400s
# (24h) matches Stripe's window. Smaller values shrink the cross-call
# protection window; larger values keep stale cache entries around
# longer.
IDEMPOTENCY_TTL_SECONDS=86400

# Provider configuration. ``auto`` picks Anthropic if ANTHROPIC_API_KEY is
# set, OpenAI if OPENAI_API_KEY is set, and the deterministic stub
# otherwise. Set explicitly (anthropic | openai | stub) to skip the
# auto-detect.
AGENT_CHAT_MODEL_PROVIDER=auto
AGENT_CHAT_MODEL_ID=
AGENT_CHAT_MODEL_TEMPERATURE=0.2

# Provider keys (optional; deterministic stubs are used when missing).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embeddings provider (Tier 8). Selection mirrors
# AGENT_CHAT_MODEL_PROVIDER. ``auto`` picks OpenAI if OPENAI_API_KEY
# is set (Anthropic has no embeddings API); otherwise the
# deterministic SHA-256 stub takes over -- ``task-estimation-agent``
# then keeps its existing neighbour-scoring path. Set explicitly
# (``openai`` | ``stub``) to skip the auto-detect. The OpenAI branch
# pins ``dimensions=16`` so swapping providers does not break
# downstream callers that snapshot vector widths. Requires the
# ``[openai]`` (or ``[ai]``) extra; the lifespan loud-fails at boot
# if the extra is missing.
EMBEDDINGS_PROVIDER=auto
EMBEDDINGS_MODEL_ID=

# LangSmith (optional).
# Setting LANGSMITH_TRACING=true at boot now mirrors the canonical
# LANGCHAIN_TRACING_V2 / LANGCHAIN_PROJECT (and LANGSMITH_*) env vars
# so the LangChain client actually ships traces. The API key itself is
# read by LangChain directly from the environment -- export
# LANGSMITH_API_KEY (or LANGCHAIN_API_KEY) from your secret manager;
# do not commit it to .env.
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=jira-python-server

# ---------------------------------------------------------------------------
# Vendor-neutral observability (opt-in)
# ---------------------------------------------------------------------------
#
# OpenTelemetry GenAI tracing and Prometheus metrics ship as a single
# optional extra (``pip install ".[observability]"`` or ``".[ai]"``).
# When neither is enabled the dev / test paths and the slim install
# stay free of the SDK dependency cost, so leaving the defaults in
# place is safe.
#
# OTEL_TRACING=true wires up an OTel ``TracerProvider`` so every
# agent run emits a span with ``gen_ai.*`` semantic-convention
# attributes (``gen_ai.operation.name``, ``gen_ai.agent.name``,
# ``gen_ai.usage.input_tokens`` / ``output_tokens``,
# ``gen_ai.response.model``). FastAPI HTTP requests get a server
# span via the FastAPI instrumentor. Operators ship the resulting
# spans to whatever backend they already run -- Datadog, Honeycomb,
# Tempo, Jaeger, Grafana Cloud -- without per-vendor field mapping.
#
# OTEL_EXPORTER_OTLP_ENDPOINT empty falls back to
# ``ConsoleSpanExporter`` so a developer can eyeball spans on stderr
# without running an OTLP collector locally; in production point this
# at the collector's HTTP receiver (e.g.
# https://otlp.example.com/v1/traces).
OTEL_TRACING=false
OTEL_SERVICE_NAME=jira-python-server
OTEL_EXPORTER_OTLP_ENDPOINT=

# PROMETHEUS_METRICS=true mounts ``GET /metrics`` (text/plain;
# version=0.0.4) and starts populating the Tier 9 counters:
# ``agent_invocations_total{agent, outcome}``,
# ``agent_tokens_total{agent, direction}``,
# ``agent_run_duration_seconds{agent, outcome}`` (with latency
# buckets sized for typical agent runs), and
# ``idempotency_cache_total{route, outcome}``. The ``replay`` outcome
# is what makes the Tier 7 ``Idempotent-Replay: true`` cache-hit
# ratio observable. Operators scrape ``/metrics`` from their
# Prometheus-compatible TSDB; the dev / test paths leave this off so
# the registry stays empty.
PROMETHEUS_METRICS=false
